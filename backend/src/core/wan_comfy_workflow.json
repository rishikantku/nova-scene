{
  "1": {
    "inputs": {
      "model": "wan2.1_i2v_720p_14B_bf16.safetensors",
      "base_precision": "bf16",
      "load_device": "offload_device",
      "attention_mode": "sdpa",
      "quantization": "disabled"
    },
    "class_type": "WanVideoModelLoader",
    "_meta": { "title": "Load WAN Model" }
  },
  "2": {
    "inputs": {
      "model_name": "umt5-xxl-enc-bf16.safetensors",
      "precision": "bf16",
      "positive_prompt": "INJECT_PROMPT",
      "negative_prompt": "worst quality, blurry, mutated, ugly, deformed",
      "quantization": "disabled",
      "use_disk_cache": true,
      "device": "gpu"
    },
    "class_type": "WanVideoTextEncodeCached",
    "_meta": { "title": "Text Encode" }
  },
  "3": {
    "inputs": {
      "image": "INJECT_IMAGE_FILENAME"
    },
    "class_type": "LoadImage",
    "_meta": { "title": "Load Image" }
  },
  "8": {
    "inputs": {
      "model_name": "wan_2.1_vae.safetensors",
      "precision": "bf16"
    },
    "class_type": "WanVideoVAELoader",
    "_meta": { "title": "Load WAN VAE" }
  },
  "4": {
    "inputs": {
      "clip_name": "clip_vision_h.safetensors",
      "width": 832,
      "height": 480,
      "num_frames": 81,
      "noise_aug_strength": 0.0,
      "start_latent_strength": 1.0,
      "end_latent_strength": 1.0,
      "force_offload": true,
      "vae": ["8", 0],
      "start_image": ["3", 0]
    },
    "class_type": "WanVideoImageToVideoEncode",
    "_meta": { "title": "I2V Encode" }
  },
  "5": {
    "inputs": {
      "steps": 30,
      "cfg": 5.0,
      "shift": 5.0,
      "seed": 42,
      "scheduler": "unipc",
      "riflex_freq_index": 0,
      "force_offload": true,
      "model": ["1", 0],
      "text_embeds": ["2", 0],
      "image_embeds": ["4", 0]
    },
    "class_type": "WanVideoSampler",
    "_meta": { "title": "Sampler" }
  },
  "6": {
    "inputs": {
      "enable_vae_tiling": true,
      "tile_x": 272,
      "tile_y": 272,
      "tile_stride_x": 144,
      "tile_stride_y": 128,
      "vae": ["8", 0],
      "samples": ["5", 0]
    },
    "class_type": "WanVideoDecode",
    "_meta": { "title": "Decode" }
  },
  "7": {
    "inputs": {
      "frame_rate": 16,
      "loop_count": 0,
      "filename_prefix": "wan_scene",
      "format": "video/h264-mp4",
      "pingpong": false,
      "save_output": true,
      "images": ["6", 0]
    },
    "class_type": "VHS_VideoCombine",
    "_meta": { "title": "Save Video" }
  }
}
